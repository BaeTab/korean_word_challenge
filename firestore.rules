rules_version = '2';

// -----------------------------------------------------------------------------
// Firestore 보안 규칙 — rankings 컬렉션
//  - 읽기: 누구나(랭킹 공개)
//  - 생성: 익명 로그인 사용자만, 스키마/범위 검증 통과 시
//  - 수정: 기존 기록보다 나을 때만 허용(닉네임당 최고기록만 유지)
//  - 삭제: 금지 (조작 방지)
//  문서 ID가 `weekKey__stage__닉네임` 이라 매주 월요일(KST) 새 문서로 자연 초기화된다.
//  (uid가 아닌 닉네임이 문서 키라 같은 닉네임을 쓰는 다른 사람과 기록을 공유하게 됨은 의도된 동작)
// -----------------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {

    match /rankings/{docId} {
      allow read: if true;

      allow create: if request.auth != null
        && isValidScore(request.resource.data);

      allow update: if request.auth != null
        && isValidScore(request.resource.data)
        && request.resource.data.nickname == resource.data.nickname
        && isBetterScore(request.resource.data, resource.data);

      allow delete: if false;
    }

    function isValidScore(d) {
      return d.keys().hasAll(['nickname', 'stage', 'attempts', 'timeMs', 'uid', 'weekKey', 'createdAt'])
        && d.nickname is string
        && d.nickname.size() >= 1 && d.nickname.size() <= 12
        && d.stage is int && d.stage >= 1 && d.stage <= 2
        && d.attempts is int && d.attempts >= 1 && d.attempts <= 6
        && d.timeMs is int && d.timeMs >= 0
        && d.weekKey is string && d.weekKey.size() == 10
        && d.uid is string && d.uid == request.auth.uid;
    }

    // 새 기록이 기존 기록보다 나을 때만 갱신 허용(시도 적은 순 → 시간 짧은 순)
    function isBetterScore(newD, oldD) {
      return newD.attempts < oldD.attempts
        || (newD.attempts == oldD.attempts && newD.timeMs < oldD.timeMs);
    }

    // 데일리 챌린지 랭킹 — 문서 ID가 `날짜__닉네임` 이라 update 금지로 하루 1회 강제
    match /daily/{docId} {
      allow read: if true;
      allow create: if request.auth != null && isValidDaily(request.resource.data);
      allow update, delete: if false;
    }

    function isValidDaily(d) {
      return d.keys().hasAll(['nickname', 'dateKey', 'attempts', 'timeMs', 'uid', 'createdAt'])
        && d.nickname is string
        && d.nickname.size() >= 1 && d.nickname.size() <= 12
        && d.dateKey is string && d.dateKey.size() == 10
        && d.attempts is int && d.attempts >= 1 && d.attempts <= 6
        && d.timeMs is int && d.timeMs >= 0
        && d.uid is string && d.uid == request.auth.uid;
    }

    // 그 외 모든 경로 접근 금지
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
